    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response contains bookingid\", function () {",
              "    pm.expect(jsonData.bookingid).to.exist;",
              "});",
              "",
              "if (jsonData.bookingid) {",
              "    pm.environment.set(\"booking_id\", jsonData.bookingid);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Tolegen\",\n  \"lastname\": \"Aibatullin\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-04-01\",\n    \"checkout\": \"2026-04-10\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/booking",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking"
          ]
        }
